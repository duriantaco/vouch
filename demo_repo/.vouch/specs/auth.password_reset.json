{
  "version": "vouch.spec.v0",
  "id": "auth.password_reset",
  "owner": "platform",
  "owned_paths": [
    "src/auth/**",
    "tests/auth/**"
  ],
  "risk": "high",
  "behavior": [
    "user can request password reset by email",
    "response does not reveal whether account exists",
    "reset token expires after 30 minutes",
    "reset token is single-use"
  ],
  "security": [
    "no account enumeration",
    "reset token is stored hashed",
    "reset endpoint is rate limited by IP and account",
    "reset token is never logged"
  ],
  "tests": {
    "required": [
      "token expires",
      "token cannot be reused",
      "unknown email receives same response shape",
      "rate limit triggers"
    ]
  },
  "runtime": {
    "metrics": [
      "password_reset.requested",
      "password_reset.completed",
      "password_reset.failed"
    ],
    "alerts": [
      "password_reset.failed > 5 percent for 10 minutes"
    ]
  },
  "rollback": {
    "strategy": "feature_flag",
    "flag": "password_reset_v2"
  }
}
